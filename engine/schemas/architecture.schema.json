{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latent-sre/schemas/v1/architecture.schema.json",
  "title": "Architecture",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "service", "spec", "provenance", "ownership", "confidence", "needs-human-review"],
  "properties": {
    "apiVersion": { "const": "sre.latent-sre/v1" },
    "kind": { "const": "Architecture" },
    "service": { "type": "string" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "style": { "enum": ["monolith", "modular-monolith", "microservice", "serverless", "unknown"] },
        "components": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": { "name": { "type": "string" }, "responsibility": { "type": "string" } }
          }
        },
        "entryPoints": { "type": "array", "items": { "type": "string" } },
        "patterns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "ownership": { "enum": ["app", "platform", "shared"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "needs-human-review": { "const": true }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "commit", "scanDate", "skill"],
      "properties": {
        "repo": { "type": "string" }, "commit": { "type": "string" },
        "scanDate": { "type": "string" }, "skill": { "type": "string" },
        "skillVersion": { "type": "string" }, "modelVersion": { "type": "string" }
      }
    }
  }
}
