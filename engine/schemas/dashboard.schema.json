{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latent-sre/schemas/v1/dashboard.schema.json",
  "title": "Dashboard",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "service", "spec", "provenance", "ownership", "confidence", "needs-human-review"],
  "properties": {
    "apiVersion": { "const": "sre.latent-sre/v1" },
    "kind": { "const": "Dashboard" },
    "service": { "type": "string" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "panels"],
      "properties": {
        "title": { "type": "string" },
        "panels": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "type"],
            "properties": {
              "title": { "type": "string" },
              "type": { "enum": ["graph", "timeseries", "stat", "table", "heatmap", "gauge"] },
              "unit": { "type": "string" },
              "signal": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "source": { "enum": ["splunk", "wavefront", "appdynamics", "thousandeyes", "otel", "grafana", "prometheus"] },
                  "query": { "type": "string" },
                  "metric": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "ownership": { "enum": ["app", "platform", "shared"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "needs-human-review": { "const": true }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "commit", "scanDate", "skill"],
      "properties": {
        "repo": { "type": "string" }, "commit": { "type": "string" },
        "scanDate": { "type": "string" }, "skill": { "type": "string" },
        "skillVersion": { "type": "string" }, "modelVersion": { "type": "string" }
      }
    }
  }
}
