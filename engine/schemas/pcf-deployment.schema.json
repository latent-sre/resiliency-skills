{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latent-sre/schemas/pcf-deployment.schema.json",
  "title": "PcfDeployment",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "service", "spec", "provenance", "ownership", "confidence", "needs-human-review"],
  "properties": {
    "apiVersion": { "const": "sre.latent-sre/v1" },
    "kind": { "const": "PcfDeployment" },
    "service": { "type": "string" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "org": { "type": "string" },
        "space": { "type": "string" },
        "instances": { "type": "integer", "minimum": 0 },
        "memory": { "type": "string" },
        "disk": { "type": "string" },
        "buildpacks": { "type": "array", "items": { "type": "string" } },
        "routes": { "type": "array", "items": { "type": "string" } },
        "boundServices": { "type": "array", "items": { "type": "string" } },
        "healthCheck": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "enum": ["port", "http", "process"] },
            "endpoint": { "type": "string" }
          }
        }
      }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "ownership": { "enum": ["app", "platform", "shared"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "needs-human-review": { "const": true }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "commit", "scanDate", "skill"],
      "properties": {
        "repo": { "type": "string" }, "commit": { "type": "string" },
        "scanDate": { "type": "string" }, "skill": { "type": "string" },
        "skillVersion": { "type": "string" }, "modelVersion": { "type": "string" }
      }
    }
  }
}
