{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latent-sre/schemas/v1/resiliency.schema.json",
  "title": "Resiliency",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "service", "spec", "provenance", "ownership", "confidence", "needs-human-review"],
  "properties": {
    "apiVersion": { "const": "sre.latent-sre/v1" },
    "kind": { "const": "Resiliency" },
    "service": { "type": "string" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "observedIn"],
            "properties": {
              "kind": { "enum": ["retry", "circuit-breaker", "timeout", "bulkhead", "fallback", "rate-limit", "idempotency", "load-shed", "backpressure"] },
              "target": { "type": "string" },
              "observedIn": { "enum": ["code", "config", "inferred"] },
              "maxAttempts": { "type": "integer", "minimum": 0 },
              "backoff": { "enum": ["none", "fixed", "exponential", "exponential-jitter"] },
              "budget": { "type": "string" },
              "timeoutMs": { "type": "integer", "minimum": 0 },
              "thresholds": { "type": "string" }
            }
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["pattern", "severity"],
            "properties": {
              "pattern": { "enum": ["retry", "circuit-breaker", "timeout", "bulkhead", "fallback", "rate-limit", "idempotency", "load-shed", "backpressure"] },
              "target": { "type": "string" },
              "severity": { "enum": ["high", "medium", "low"] },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "ownership": { "enum": ["app", "platform", "shared"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "needs-human-review": { "const": true }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "commit", "scanDate", "skill"],
      "properties": {
        "repo": { "type": "string" }, "commit": { "type": "string" },
        "scanDate": { "type": "string" }, "skill": { "type": "string" },
        "skillVersion": { "type": "string" }, "modelVersion": { "type": "string" }
      }
    }
  }
}
