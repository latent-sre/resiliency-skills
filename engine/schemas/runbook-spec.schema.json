{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latent-sre/schemas/runbook-spec.schema.json",
  "title": "RunbookSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "service", "spec", "provenance", "ownership", "confidence", "needs-human-review"],
  "properties": {
    "apiVersion": { "const": "sre.latent-sre/v1" },
    "kind": { "const": "RunbookSpec" },
    "service": { "type": "string" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "severity": { "enum": ["sev1", "sev2", "sev3"] },
        "signals": { "type": "array", "items": { "type": "string" } },
        "triage": { "type": "array", "items": { "type": "string" } },
        "mitigation": { "type": "array", "items": { "type": "string" } },
        "rollback": { "type": "array", "items": { "type": "string" } },
        "escalation": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "team": { "type": "string" } }
        },
        "links": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "dashboard": { "type": "string" }, "slo": { "type": "string" }, "alert": { "type": "string" } }
        }
      }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "ownership": { "enum": ["app", "platform", "shared"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "needs-human-review": { "const": true }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "commit", "scanDate", "skill"],
      "properties": {
        "repo": { "type": "string" }, "commit": { "type": "string" },
        "scanDate": { "type": "string" }, "skill": { "type": "string" },
        "skillVersion": { "type": "string" }, "modelVersion": { "type": "string" }
      }
    }
  }
}
