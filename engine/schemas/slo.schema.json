{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latent-sre/schemas/slo.schema.json",
  "title": "Slo",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "service", "spec", "provenance", "ownership", "confidence", "needs-human-review"],
  "properties": {
    "apiVersion": { "const": "sre.latent-sre/v1" },
    "kind": { "const": "Slo" },
    "service": { "type": "string" },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sli", "objectives"],
      "properties": {
        "sli": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "type"],
          "properties": {
            "name": { "type": "string" },
            "type": { "enum": ["ratio", "threshold"] },
            "source": { "enum": ["splunk", "wavefront", "appdynamics", "thousandeyes", "otel", "grafana", "prometheus"] },
            "good": { "type": "string" },
            "total": { "type": "string" },
            "metric": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "objectives": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target", "window"],
            "properties": {
              "displayName": { "type": "string" },
              "target": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
              "window": { "type": "string" }
            }
          }
        },
        "errorBudgetPolicy": { "type": "array", "items": { "type": "string" } }
      }
    },
    "provenance": { "$ref": "#/$defs/provenance" },
    "ownership": { "enum": ["app", "platform", "shared"] },
    "confidence": { "enum": ["high", "medium", "low"] },
    "needs-human-review": { "const": true }
  },
  "$defs": {
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "commit", "scanDate", "skill"],
      "properties": {
        "repo": { "type": "string" }, "commit": { "type": "string" },
        "scanDate": { "type": "string" }, "skill": { "type": "string" },
        "skillVersion": { "type": "string" }, "modelVersion": { "type": "string" }
      }
    }
  }
}
