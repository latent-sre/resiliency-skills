# Grafana alerting rule (deliverable). Rendered deterministically from a neutral AlertIntent.
# unverified-against-live: review before applying.
apiVersion: 1
groups:
  - name: {{ service | tojson }}
    folder: sre-generated
    rules:
      - uid: {{ name | tojson }}
        title: {{ name | tojson }}
        for: {{ for | tojson }}
        labels:
          severity: {{ severity | tojson }}
          class: {{ severity_class | tojson }}
          ownership: {{ ownership | tojson }}
        annotations:
          summary: {{ summary | tojson }}
          runbook_url: {{ runbook | tojson }}
        # signal {{ comparator | sanitize }} {{ threshold | tojson }} over {{ window | tojson }}{% if occurrences %}, x{{ occurrences }} occurrences{% endif %}
        # query: {{ query | tojson }}
